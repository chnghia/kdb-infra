# KDB Infrastructure Configuration (Example)

# === Neo4j (Graph Database) ===
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_change_me

# === PostgreSQL (Backoffice MetaDB) ===
POSTGRES_DB=kdb_backoffice
POSTGRES_USER=kdb_user
POSTGRES_PASSWORD=kdb_password_change_me
POSTGRES_PORT=5433

# === MinIO (Object Storage) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === Qdrant (Vector Database) ===
# Qdrant defaults are often sufficient for local dev
